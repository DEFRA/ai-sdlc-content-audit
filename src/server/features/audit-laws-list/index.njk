{% extends "layouts/page.njk" %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Choose a category", href: "/" },
      { text: category.title, href: "/audit/subjects/" + category.id },
      { text: "Laws" }
    ]
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-three-quarters">
        <h1 class="govuk-heading-xl">{{ heading }}</h1>
        <p class="govuk-body">These are the laws we found that apply to this subject.</p>

        {% if hasResults %}
          <table class="govuk-table">
            <caption class="govuk-table__caption govuk-visually-hidden">Laws found for this subject</caption>
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Law</th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric">Rules in the law</th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric">Rules with guidance</th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric">Conflicts</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              {% for row in rows %}
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell">
                    <a class="govuk-link" href="{{ row.url }}" rel="noopener noreferrer" target="_blank">{{ row.name }}</a>
                    <br>
                    <span class="govuk-body-s" style="color:#505a5f;">Opens on legislation.gov.uk</span>
                  </td>
                  <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.propositionCount }}</td>
                  <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.propositionsWithGuidance }}</td>
                  <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.conflictsCount }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        {% else %}
          <p class="govuk-body">We did not find any laws for this subject.</p>
        {% endif %}

        <p class="govuk-body govuk-!-margin-top-6">
          <a class="govuk-link" href="{{ backHref }}">Back to {{ category.title }}</a>
        </p>
      </div>
    </div>
  </div>
{% endblock %}
