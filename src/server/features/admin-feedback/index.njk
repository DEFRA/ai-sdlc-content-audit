{% extends "layouts/page.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-three-quarters">
        <h1 class="govuk-heading-xl">Feedback admin</h1>

        {{ govukWarningText({
          text: "Internal review surface. Do not share publicly — anyone with the link can read everything submitted.",
          iconFallbackText: "Warning"
        }) }}

        {% if cleared %}
          {{ govukNotificationBanner({
            type: "success",
            text: "All feedback cleared."
          }) }}
        {% endif %}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Download all feedback",
            href: "/admin/feedback.json",
            classes: "govuk-button--secondary"
          }) }}

          <form method="post" action="/admin/clear" style="display:inline-block;margin:0;">
            {{ govukButton({
              text: "Clear all feedback",
              classes: "govuk-button--warning"
            }) }}
          </form>
        </div>

        {% if hasRows %}
          <table class="govuk-table">
            <caption class="govuk-table__caption govuk-table__caption--m">
              {{ rows | length }} feedback {{ "entry" if rows | length == 1 else "entries" }}
            </caption>
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Submitted</th>
                <th scope="col" class="govuk-table__header">Current status</th>
                <th scope="col" class="govuk-table__header">Suggested status</th>
                <th scope="col" class="govuk-table__header">Comment</th>
                <th scope="col" class="govuk-table__header">Source</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              {% for row in rows %}
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell">{{ row.submittedAt }}</td>
                  <td class="govuk-table__cell">{{ row.currentStatusLabel }}</td>
                  <td class="govuk-table__cell">{{ row.suggestedStatusLabel or "—" }}</td>
                  <td class="govuk-table__cell">{{ row.comment or "—" }}</td>
                  <td class="govuk-table__cell">
                    <a class="govuk-link" href="{{ row.pageHref }}">View proposition</a>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        {% else %}
          <p class="govuk-body">No feedback has been submitted yet.</p>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
