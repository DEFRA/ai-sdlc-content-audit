{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/character-count/macro.njk" import govukCharacterCount %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{#
  Renders the per-proposition feedback form.
  Required context:
    categoryId, pageId, matchId, widget
    feedback (object or null) — { choice, comment, updatedAtLabel, ... }
#}

{% set actionUrl = "/audit/subjects/" + categoryId + "/pages/" + pageId + "/propositions/" + matchId + "/feedback" %}
{% set isCompleted = feedback != null %}
{% set buttonText = "Save changes" if isCompleted else "Submit feedback" %}
{% set legendText = "Update your feedback" if isCompleted else "Your feedback" %}
{% set selectedChoice = feedback.choice if isCompleted else "" %}
{% set commentValue = feedback.comment if isCompleted else "" %}

<form method="post" action="{{ actionUrl }}" class="app-proposition-feedback govuk-!-margin-top-4" novalidate>
  {{ govukRadios({
    name: "choice",
    idPrefix: "choice-" + matchId,
    fieldset: {
      legend: {
        text: legendText,
        classes: "govuk-fieldset__legend--s"
      }
    },
    items: [
      { value: "INTERESTED", text: "I am interested in this", checked: selectedChoice == "INTERESTED" },
      { value: "NOT_INTERESTED", text: "I am not interested in this", checked: selectedChoice == "NOT_INTERESTED" },
      { value: "AI_MISTAKE", text: "This is a mistake in the AI", checked: selectedChoice == "AI_MISTAKE" }
    ]
  }) }}

  {{ govukCharacterCount({
    id: "comment-" + matchId,
    name: "comment",
    label: { text: "Add a comment (optional)" },
    maxlength: widget.commentMaxLength,
    threshold: 80,
    rows: 3,
    value: commentValue
  }) }}

  {{ govukButton({
    text: buttonText,
    preventDoubleClick: true
  }) }}

  {% if isCompleted and feedback.updatedAtLabel %}
    <p class="govuk-hint govuk-!-margin-top-2">Last saved {{ feedback.updatedAtLabel }}.</p>
  {% endif %}
</form>
