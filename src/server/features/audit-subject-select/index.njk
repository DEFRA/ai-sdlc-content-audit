{% extends "layouts/page.njk" %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: "/" },
      { text: "Choose a subject" }
    ]
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">{{ heading }}</h1>
        <p class="govuk-body-l">{{ intro }}</p>

        {% if hasSubjects %}
          <form method="get" action="/audit" novalidate>
            <div class="govuk-form-group">
              <label class="govuk-label govuk-label--m" for="subject">{{ inputLabel }}</label>
              <div class="govuk-hint" id="subject-hint">{{ inputHint }}</div>
              <select class="govuk-select" id="subject" name="subject" aria-describedby="subject-hint">
                {% for option in options %}
                  <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.text }}</option>
                {% endfor %}
              </select>
            </div>
            <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ buttonText }}</button>
          </form>

          {% if selected %}
            <div class="govuk-inset-text govuk-!-margin-top-6">
              <h2 class="govuk-heading-m govuk-!-margin-bottom-2">{{ selected.title }}</h2>
              <p class="govuk-body">{{ selected.description }}</p>
              <a href="/audit/subjects/{{ selected.id }}" role="button" draggable="false" class="govuk-button govuk-!-margin-top-2" data-module="govuk-button">
                Find related guidance
              </a>
            </div>
          {% endif %}
        {% else %}
          <p class="govuk-body">We have not finished checking any subjects yet. Please check back later.</p>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
