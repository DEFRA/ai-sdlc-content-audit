{% extends "layouts/page.njk" %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: "/" },
      { text: "Choose a category" }
    ]
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl">{{ heading }}</h1>
        <p class="govuk-body-l">{{ intro }}</p>

        {% if hasCategories %}
          <ul class="govuk-list">
            {% for category in categories %}
              <li class="govuk-!-margin-bottom-6">
                <h2 class="govuk-heading-m govuk-!-margin-bottom-2">{{ category.title }}</h2>
                <p class="govuk-body">{{ category.description }}</p>
                <a href="{{ category.href }}" role="button" draggable="false" class="govuk-button" data-module="govuk-button">
                  View results
                </a>
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <p class="govuk-body">We have not finished checking any categories yet. Please check back later.</p>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
