{% extends "layouts/page.njk" %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Choose a category", href: "/" },
      { text: category.title, href: "/audit/subjects/" + category.id },
      { text: "Pages", href: backHref },
      { text: page.title }
    ]
  }) }}
{% endblock %}

{% macro statementCard(s, isCompleted) %}
  {% set borderColour = "#b1b4b6" %}
  {% if s.statusTone == "red" %}{% set borderColour = "#d4351c" %}{% endif %}
  {% if s.statusTone == "yellow" %}{% set borderColour = "#ffdd00" %}{% endif %}
  {% if s.statusTone == "green" %}{% set borderColour = "#00703c" %}{% endif %}

  {% set anchor = ("completed-feedback-" if isCompleted else "pending-feedback-") + s.id %}

  <div id="{{ anchor }}" class="govuk-summary-card govuk-!-margin-bottom-4" style="border-top:6px solid {{ borderColour }};">
    <div class="govuk-summary-card__title-wrapper">
      <h3 class="govuk-summary-card__title govuk-heading-s govuk-!-margin-bottom-0">
        {{ s.statusLabel }}
      </h3>
      <strong class="govuk-tag govuk-tag--{{ s.statusTone }}">{{ s.statusLabel }}</strong>
    </div>
    <div class="govuk-summary-card__content">
      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key" style="width:25%;">This guidance says</dt>
          <dd class="govuk-summary-list__value">{{ s.guidanceText }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Our finding</dt>
          <dd class="govuk-summary-list__value">{{ s.explanation if s.explanation else s.statusMeaning }}</dd>
        </div>
        {% if s.lawName %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Related law</dt>
            <dd class="govuk-summary-list__value">
              <a class="govuk-link" href="{{ s.lawUrl }}" rel="noopener noreferrer" target="_blank">{{ s.lawName }}</a>
            </dd>
          </div>
        {% endif %}
        {% if s.lawText %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">What the law says</dt>
            <dd class="govuk-summary-list__value">{{ s.lawText }}</dd>
          </div>
        {% endif %}
      </dl>
      {% set matchId = s.id %}
      {% set feedback = s.feedback %}
      {% set widget = feedbackWidget %}
      {% include "features/proposition-feedback/index.njk" %}
    </div>
  </div>
{% endmacro %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-three-quarters">
        <h1 class="govuk-heading-xl">{{ page.title }}</h1>
        <p class="govuk-body">
          <a class="govuk-link" href="{{ page.url }}" rel="noopener noreferrer" target="_blank">View the live page (opens in new tab)</a>
        </p>

        {% if savedMatchId %}
          {{ govukNotificationBanner({
            type: "success",
            text: "Your feedback has been saved."
          }) }}
        {% endif %}

        <nav aria-label="Jump to section" class="govuk-!-margin-bottom-6">
          <ul class="govuk-list">
            <li>
              <a class="govuk-link" href="#pending-feedback">Pending feedback ({{ pending | length }})</a>
            </li>
            <li>
              <a class="govuk-link" href="#completed-feedback">Completed feedback ({{ completed | length }})</a>
            </li>
          </ul>
        </nav>

        <section id="pending-feedback" aria-labelledby="pending-feedback-heading">
          <h2 id="pending-feedback-heading" class="govuk-heading-l govuk-!-margin-top-6">Pending feedback</h2>
          {% if hasPending %}
            {% for s in pending %}
              {{ statementCard(s, false) }}
            {% endfor %}
          {% else %}
            <p class="govuk-body">No statements are waiting for feedback on this page.</p>
          {% endif %}
        </section>

        <section id="completed-feedback" aria-labelledby="completed-feedback-heading">
          <h2 id="completed-feedback-heading" class="govuk-heading-l govuk-!-margin-top-8">Completed feedback</h2>
          {% if hasCompleted %}
            {% for s in completed %}
              {{ statementCard(s, true) }}
            {% endfor %}
          {% else %}
            <p class="govuk-body">You have not submitted feedback on any statements on this page yet.</p>
          {% endif %}
        </section>
      </div>
    </div>
  </div>
{% endblock %}
