{% extends "layouts/page.njk" %}

{% block beforeContent %}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: "/" },
      { text: "Choose a subject", href: "/audit" },
      { text: category.title }
    ]
  }) }}
{% endblock %}

{% block content %}
  <div class="govuk-width-container">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-three-quarters">
        <h1 class="govuk-heading-xl">{{ category.title }}</h1>

        <h2 class="govuk-heading-l govuk-!-margin-top-6">What we audited</h2>

        <dl class="govuk-summary-list govuk-summary-list--no-border">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Initial search term</dt>
            <dd class="govuk-summary-list__value">{{ initialSearchTerm }}</dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">What this covers</dt>
            <dd class="govuk-summary-list__value">{{ expandedDescription }}</dd>
          </div>
        </dl>

        <details class="govuk-details" data-module="govuk-details">
          <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">How we chose this description</span>
          </summary>
          <div class="govuk-details__text">
            <p class="govuk-body">
              We started from the search term <strong>{{ initialSearchTerm }}</strong>.
              On its own that is a short phrase, which makes it hard to match against
              long pieces of guidance and law.
            </p>
            <p class="govuk-body">
              Using a mix of techniques based on <em>semantic similarity searching</em>
              (matching by meaning, not just by exact words), we expanded the search term
              into the longer description above. The longer description has more clues in it,
              so it finds more of the guidance pages and laws that really belong to this subject.
            </p>
          </div>
        </details>

        <h2 class="govuk-heading-l govuk-!-margin-top-6">What we found</h2>
        <dl class="govuk-summary-list">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Laws we found</dt>
            <dd class="govuk-summary-list__value">
              <a class="govuk-link govuk-!-font-size-24" href="{{ lawsHref }}">{{ lawsFound }}</a>
            </dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Pages we checked</dt>
            <dd class="govuk-summary-list__value"><strong class="govuk-!-font-size-24">{{ totalPagesAudited | string }}</strong></dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">Pages about this subject</dt>
            <dd class="govuk-summary-list__value">
              <a class="govuk-link govuk-!-font-size-24" href="{{ pagesHref }}">{{ pagesRelevant }}</a>
            </dd>
          </div>
        </dl>

        {% if hasRelevantPages %}
          <h2 class="govuk-heading-l govuk-!-margin-top-6">How the guidance is doing</h2>

          <div class="audit-score-panel govuk-!-margin-bottom-4" style="border-left:10px solid {% if guidanceScoreBand.colour == 'green' %}#00703c{% elif guidanceScoreBand.colour == 'yellow' %}#ffdd00{% elif guidanceScoreBand.colour == 'orange' %}#f47738{% elif guidanceScoreBand.colour == 'red' %}#d4351c{% else %}#b1b4b6{% endif %};padding:16px 20px;background:#f3f2f1;">
            <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Overall guidance score</p>
            <p class="govuk-heading-xl govuk-!-margin-bottom-1">{{ guidanceScoreDisplay }}</p>
            <p class="govuk-body govuk-!-margin-bottom-0">
              <strong class="govuk-tag govuk-tag--{{ guidanceScoreBand.colour }}">{{ guidanceScoreBand.label }}</strong>
              — based on every statement we checked across all pages about this subject.
            </p>
          </div>

          <p class="govuk-body">
            We broke each page down into individual statements (called <em>propositions</em>) and checked each one against the law.
            The numbers below show the total number of statements we found in each group.
          </p>

          <ul class="audit-status-grid">
            {% for box in breakdownBoxes %}
              <li>
                <div class="audit-status-tile{% if not box.href %} audit-status-tile--empty{% endif %}">
                  <strong class="govuk-tag govuk-tag--{{ box.tone }} audit-status-tile__tag">{{ box.title }}</strong>
                  <p class="audit-status-tile__count">{{ box.count }}</p>
                  <p class="audit-status-tile__spread">{{ box.spread }}</p>
                  <p class="audit-status-tile__meaning">{{ box.meaning }}</p>
                  {% if box.href %}
                    <p class="audit-status-tile__cta">
                      <a class="govuk-link audit-status-tile__link" href="{{ box.href }}">{{ box.cta }}</a>
                    </p>
                  {% endif %}
                </div>
              </li>
            {% endfor %}
          </ul>

          <a href="{{ pagesHref }}" role="button" draggable="false" class="govuk-button govuk-!-margin-top-4" data-module="govuk-button">
            See all pages about this subject
          </a>
        {% else %}
          <p class="govuk-body">We could not find any guidance pages about this subject.</p>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
